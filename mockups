<body>
<div id="root"></div>
<script type="text/babel">
const { useState, useCallback, useRef } = React;



/* ── civ.works Design System ──────────────────────────────── */
const C = {
  dark: "#0a0a0a", darker: "#050505", surface: "#111111", card: "#161616",
  input: "#1a1a1a", border: "rgba(255,255,255,0.08)",
  purple: "#7C3AED", purpleDark: "#6D28D9", purpleLight: "#8B5CF6",
  purpleDim: "rgba(124,58,237,0.12)",
  green: "#10B981", greenDim: "rgba(16,185,129,0.12)",
  amber: "#F59E0B", amberDim: "rgba(245,158,11,0.12)",
  red: "#EF4444", blue: "#3B82F6", blueDim: "rgba(59,130,246,0.12)",
  white: "#ffffff", offWhite: "#f5f5f5", grey: "#a3a3a3",
  greyDark: "#525252", textMuted: "#6b7280",
};

/* Fonts loaded via HTML head */

const H = "'Special Elite', monospace";
const B = "'Open Sans', sans-serif";

/* ── Logo ─────────────────────────────────────────────────── */
function CivLogo({ size = 28 }) {
  return (
    <div style={{ display: "flex", alignItems: "center", gap: 8 }}>
      <div style={{ width: size, height: size, background: C.white, borderRadius: 4, padding: 2, display: "flex", alignItems: "center", justifyContent: "center" }}>
        <svg viewBox="0 0 40 40" width={size - 4} height={size - 4}>
          <rect width="40" height="40" rx="4" fill={C.white} />
          <text x="20" y="28" textAnchor="middle" fontFamily={H} fontSize="22" fill={C.dark}>cw</text>
          <circle cx="33" cy="10" r="4" fill={C.purple} />
        </svg>
      </div>
      <span style={{ fontFamily: H, fontSize: size * 0.55, color: C.offWhite }}>
        civ<span style={{ color: C.purple }}>.</span>works
      </span>
    </div>
  );
}

function Badge({ children, color, bg }) {
  return <span style={{ fontSize: 10, fontWeight: 700, fontFamily: B, textTransform: "uppercase", letterSpacing: "0.06em", padding: "3px 8px", borderRadius: 4, background: bg || C.purpleDim, color: color || C.purple, display: "inline-block" }}>{children}</span>;
}

function Card({ children, style: sx }) {
  return <div style={{ background: C.card, border: `1px solid ${C.border}`, borderRadius: 10, padding: 24, ...sx }}>{children}</div>;
}

function PrivacyNote({ children }) {
  return (
    <div style={{ marginTop: 18, padding: 12, borderRadius: 8, background: C.purpleDim, fontSize: 12, fontFamily: B, color: C.purpleLight, lineHeight: 1.5, display: "flex", alignItems: "flex-start", gap: 8, border: "1px solid rgba(124,58,237,0.15)" }}>
      <span style={{ fontSize: 15, flexShrink: 0 }}>🔒</span><span>{children}</span>
    </div>
  );
}

/* ════════════════════════════════════════════════════════════
   MOCKUP 1: LARGE-SCALE ORG ANALYTICS (20,000 subscribers)
   ════════════════════════════════════════════════════════════ */

function OrgAnalyticsMockup() {
  const action = {
    title: "National Day of Action: Defend Democracy",
    org: "United Democracy Coalition",
    date: "2026-03-01",
    scope: "National",
    issues: ["Government", "Voting Rights", "Corruption", "Equality"]
  };

  const stats = { views: 89420, calendared: 23847, completed: 20103, shared: 12340 };
  const completionRate = Math.round(stats.completed / stats.views * 100);
  const calendarRate = Math.round(stats.calendared / stats.views * 100);

  const channelData = [
    { channel: "CivicWorks Feed", views: 31200, cal: 8340, completed: 7120, pct: 35 },
    { channel: "Bluesky", views: 24600, cal: 6540, completed: 5480, pct: 28 },
    { channel: "Subscriber Push", views: 18900, cal: 5630, completed: 4890, pct: 21 },
    { channel: "Email Digest", views: 14720, cal: 3337, completed: 2613, pct: 16 },
  ];

  const regionData = [
    { region: "Southwest (AZ, NM, NV)", subs: 4280, completed: 3620, pct: 85 },
    { region: "Pacific (CA, OR, WA)", subs: 5120, completed: 4210, pct: 82 },
    { region: "Northeast (NY, MA, PA)", subs: 3890, completed: 3150, pct: 81 },
    { region: "Midwest (IL, MI, OH)", subs: 3640, completed: 2870, pct: 79 },
    { region: "Southeast (GA, FL, NC)", subs: 3210, completed: 2490, pct: 78 },
    { region: "Mountain (CO, UT, MT)", subs: 2100, completed: 1680, pct: 80 },
    { region: "Other regions", subs: 1607, completed: 2083, pct: 77 },
  ];

  const issueAffinity = [
    { issue: "Government", pct: 94 },
    { issue: "Voting Rights", pct: 87 },
    { issue: "Corruption", pct: 82 },
    { issue: "Equality", pct: 71 },
    { issue: "Climate / Environment", pct: 48 },
    { issue: "Health Care", pct: 39 },
  ];

  const timelineData = [
    { day: "Feb 15", event: "Published", metric: "—" },
    { day: "Feb 16-20", event: "Initial distribution", metric: "+12,400 views" },
    { day: "Feb 21-25", event: "Organic sharing peak", metric: "+34,200 views" },
    { day: "Feb 26-28", event: "Calendar reminders sent", metric: "+8,900 calendared" },
    { day: "Mar 1", event: "Action day", metric: "20,103 completed" },
    { day: "Mar 2", event: "Analytics finalized", metric: "22.5% completion rate" },
  ];

  return (
    <div style={{ maxWidth: 640, margin: "0 auto", padding: "40px 24px" }}>
      <div style={{ display: "flex", alignItems: "center", gap: 10, marginBottom: 8 }}>
        <Badge color={C.green} bg={C.greenDim}>Completed</Badge>
        <Badge color={C.purpleLight} bg={C.purpleDim}>National</Badge>
      </div>
      <h2 style={{ fontFamily: H, fontSize: 26, color: C.offWhite, marginBottom: 4 }}>{action.title}</h2>
      <p style={{ fontFamily: B, fontSize: 14, color: C.grey, marginBottom: 6 }}>{action.org}</p>
      <p style={{ fontFamily: B, fontSize: 13, color: C.textMuted, marginBottom: 28 }}>Action Date: March 1, 2026 — Analytics as of March 2, 2026</p>

      {/* Hero Stats */}
      <Card style={{ marginBottom: 14, background: "linear-gradient(135deg, #161616 0%, #1a1028 100%)" }}>
        <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr 1fr", gap: 16 }}>
          {[
            { label: "Total Views", value: stats.views.toLocaleString(), color: C.blue },
            { label: "Calendared", value: stats.calendared.toLocaleString(), color: C.amber },
            { label: "Completed", value: stats.completed.toLocaleString(), color: C.green },
            { label: "Shared", value: stats.shared.toLocaleString(), color: C.purpleLight },
          ].map((s, i) => (
            <div key={i} style={{ textAlign: "center" }}>
              <div style={{ fontSize: 28, fontFamily: H, color: s.color }}>{s.value}</div>
              <div style={{ fontSize: 11, fontFamily: B, color: C.textMuted, marginTop: 2 }}>{s.label}</div>
            </div>
          ))}
        </div>
        <div style={{ marginTop: 20, display: "flex", gap: 12 }}>
