            <div style={{ fontSize: 24, fontFamily: H, color: C.green }}>{completionRate}%</div>
            <div style={{ fontSize: 11, fontFamily: B, color: C.green }}>Completion Rate</div>
          </div>
          <div style={{ flex: 1, padding: 12, background: "rgba(245,158,11,0.08)", borderRadius: 8, textAlign: "center", border: "1px solid rgba(245,158,11,0.15)" }}>
            <div style={{ fontSize: 24, fontFamily: H, color: C.amber }}>{calendarRate}%</div>
            <div style={{ fontSize: 11, fontFamily: B, color: C.amber }}>Calendar Rate</div>
          </div>
          <div style={{ flex: 1, padding: 12, background: "rgba(139,92,246,0.08)", borderRadius: 8, textAlign: "center", border: "1px solid rgba(139,92,246,0.15)" }}>
            <div style={{ fontSize: 24, fontFamily: H, color: C.purpleLight }}>84%</div>
            <div style={{ fontSize: 11, fontFamily: B, color: C.purpleLight }}>Calendar→Complete</div>
          </div>
        </div>
      </Card>

      {/* Engagement Funnel */}
      <Card style={{ marginBottom: 14 }}>
        <div style={{ fontSize: 11, fontWeight: 700, fontFamily: B, textTransform: "uppercase", letterSpacing: "0.08em", color: C.textMuted, marginBottom: 16 }}>Engagement Funnel</div>
        {[
          { label: "Viewed", val: stats.views, pct: 100, color: C.blue },
          { label: "Calendared", val: stats.calendared, pct: calendarRate, color: C.amber },
          { label: "Completed", val: stats.completed, pct: completionRate, color: C.green },
          { label: "Shared", val: stats.shared, pct: Math.round(stats.shared / stats.views * 100), color: C.purpleLight },
        ].map((row, i) => (
          <div key={i} style={{ marginBottom: 14 }}>
            <div style={{ display: "flex", justifyContent: "space-between", fontSize: 13, fontFamily: B, marginBottom: 4 }}>
              <span style={{ color: C.grey }}>{row.label}</span>
              <span style={{ color: C.offWhite, fontWeight: 600 }}>{row.val.toLocaleString()} <span style={{ color: C.textMuted, fontWeight: 400 }}>({row.pct}%)</span></span>
            </div>
            <div style={{ height: 8, borderRadius: 4, background: C.input }}>
              <div style={{ height: "100%", borderRadius: 4, width: `${row.pct}%`, background: row.color, transition: "width 1s ease" }} />
            </div>
          </div>
        ))}
      </Card>

      {/* Distribution Channels */}
      <Card style={{ marginBottom: 14 }}>
        <div style={{ fontSize: 11, fontWeight: 700, fontFamily: B, textTransform: "uppercase", letterSpacing: "0.08em", color: C.textMuted, marginBottom: 16 }}>Distribution Channel Performance</div>
        <div style={{ display: "grid", gridTemplateColumns: "1fr", gap: 0 }}>
          {channelData.map((ch, i) => (
            <div key={i} style={{ padding: "12px 0", borderBottom: i < channelData.length - 1 ? `1px solid ${C.border}` : "none" }}>
              <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 6 }}>
                <span style={{ fontSize: 14, fontFamily: B, fontWeight: 500, color: C.offWhite }}>{ch.channel}</span>
                <span style={{ fontSize: 12, fontFamily: B, color: C.textMuted }}>{ch.pct}% of traffic</span>
              </div>
              <div style={{ display: "flex", gap: 20, fontSize: 12, fontFamily: B }}>
                <span style={{ color: C.blue }}>{ch.views.toLocaleString()} views</span>
                <span style={{ color: C.amber }}>{ch.cal.toLocaleString()} calendared</span>
                <span style={{ color: C.green }}>{ch.completed.toLocaleString()} completed</span>
              </div>
            </div>
          ))}
        </div>
      </Card>

      {/* Regional Breakdown */}
      <Card style={{ marginBottom: 14 }}>
        <div style={{ fontSize: 11, fontWeight: 700, fontFamily: B, textTransform: "uppercase", letterSpacing: "0.08em", color: C.textMuted, marginBottom: 16 }}>Regional Participation</div>
        {regionData.map((r, i) => (
          <div key={i} style={{ marginBottom: 12 }}>
            <div style={{ display: "flex", justifyContent: "space-between", fontSize: 13, fontFamily: B, marginBottom: 4 }}>
              <span style={{ color: C.grey }}>{r.region}</span>
              <span style={{ color: C.offWhite, fontWeight: 500 }}>{r.completed.toLocaleString()} / {r.subs.toLocaleString()} <span style={{ color: C.green }}>({r.pct}%)</span></span>
            </div>
            <div style={{ height: 6, borderRadius: 3, background: C.input }}>
              <div style={{ height: "100%", borderRadius: 3, width: `${r.pct}%`, background: `linear-gradient(90deg, ${C.purple}, ${C.green})` }} />
            </div>
          </div>
        ))}
      </Card>

      {/* Issue Affinity of Participants */}
      <Card style={{ marginBottom: 14 }}>
        <div style={{ fontSize: 11, fontWeight: 700, fontFamily: B, textTransform: "uppercase", letterSpacing: "0.08em", color: C.textMuted, marginBottom: 16 }}>Participant Issue Affinity Profile</div>
        <p style={{ fontSize: 12, fontFamily: B, color: C.textMuted, marginBottom: 14 }}>Top issue interests among the 20,103 participants (aggregate, anonymized)</p>
        {issueAffinity.map((iss, i) => (
          <div key={i} style={{ display: "flex", alignItems: "center", gap: 12, marginBottom: 10 }}>
            <span style={{ fontSize: 12, fontFamily: B, color: C.grey, width: 160, flexShrink: 0 }}>{iss.issue}</span>
            <div style={{ flex: 1, height: 6, borderRadius: 3, background: C.input }}>
              <div style={{ height: "100%", borderRadius: 3, width: `${iss.pct}%`, background: C.purpleLight }} />
            </div>
            <span style={{ fontSize: 12, fontFamily: B, color: C.purpleLight, width: 36, textAlign: "right" }}>{iss.pct}%</span>
          </div>
        ))}
      </Card>

      {/* Timeline */}
      <Card style={{ marginBottom: 14 }}>
        <div style={{ fontSize: 11, fontWeight: 700, fontFamily: B, textTransform: "uppercase", letterSpacing: "0.08em", color: C.textMuted, marginBottom: 16 }}>Campaign Timeline</div>
        {timelineData.map((t, i) => (
          <div key={i} style={{ display: "flex", gap: 14, paddingBottom: 14, marginBottom: 14, borderBottom: i < timelineData.length - 1 ? `1px solid ${C.border}` : "none" }}>
            <div style={{ width: 10, display: "flex", flexDirection: "column", alignItems: "center", paddingTop: 4 }}>
              <div style={{ width: 10, height: 10, borderRadius: "50%", background: i === timelineData.length - 1 ? C.green : C.purple, flexShrink: 0 }} />
              {i < timelineData.length - 1 && <div style={{ width: 1, flex: 1, background: C.border, marginTop: 4 }} />}
            </div>
            <div>
              <div style={{ fontSize: 12, fontFamily: B, color: C.textMuted }}>{t.day}</div>
              <div style={{ fontSize: 14, fontFamily: B, fontWeight: 500, color: C.offWhite }}>{t.event}</div>
              <div style={{ fontSize: 13, fontFamily: B, color: C.green }}>{t.metric}</div>
            </div>
          </div>
        ))}
      </Card>

      <PrivacyNote>
        All analytics are aggregate only. No individual subscriber identities, locations, or behaviors are included in this report. Regional data uses city-level precision only. CivicWorks does not retain individual participation records after aggregation.
      </PrivacyNote>
    </div>
  );
}

